{
  "channels": [
    {
      "id": "telegram",
      "provider": "telegram",
      "enabled": true,
      "send_enabled": false,
      "auto_reply": false,
      "token_env": "TELEGRAM_BOT_TOKEN",
      "settings": {
        "admin_enabled": false,
        "allowed_conversation_ids": [],
        "allowed_user_ids": [],
        "owner_user_ids": [],
        "signature_provider": "telegram",
        "signature_secret_env": "TELEGRAM_WEBHOOK_SECRET"
      }
    },
    {
      "id": "discord",
      "provider": "discord",
      "enabled": true,
      "send_enabled": false,
      "auto_reply": false,
      "webhook_url_env": "DISCORD_WEBHOOK_URL"
    },
    {
      "id": "webhook",
      "provider": "webhook",
      "enabled": true,
      "send_enabled": false,
      "auto_reply": false,
      "webhook_url_env": "NEST_AGENT_CHANNEL_WEBHOOK_URL"
    }
  ]
}
