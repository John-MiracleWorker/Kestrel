{
  "name": "Kestrel",
  "provider": "openai",
  "model": "gpt-5.5",
  "base_url": null,
  "api_key_env": "OPENAI_API_KEY",
  "timeout_seconds": 60,
  "max_retries": 2,
  "temperature": 0.2,
  "codex_sandbox": "read-only",
  "codex_profile": null,
  "codex_skip_git_repo_check": false,
  "codex_ephemeral": true,
  "backend": "memvid",
  "memory_dir": ".nest/memory",
  "workspace": ".",
  "max_tool_rounds": 6,
  "context_budget_chars": 18000,
  "task_capsule_retention_count": 1000,
  "enable_semantic_orchestration": false,
  "enable_proactive_routines": false,
  "routine_poll_interval_seconds": 30.0,
  "routine_claim_ttl_seconds": 120.0,
  "max_routines_per_tick": 3,
  "allow_shell": false,
  "allow_file_write": false,
  "allow_policy_writes": false,
  "allow_codex_cli": false,
  "require_approval_for_high_risk_tools": true,
  "stream": false,
  "log_dir": ".nest/logs",
  "channel_config_path": ".nest/config/channels.json",
  "enable_channel_delivery": false,
  "channel_send_timeout_seconds": 10
}
