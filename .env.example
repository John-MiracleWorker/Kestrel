# Provider keys. Keep unused providers blank; do not commit real secrets.
# Memvid can use local embeddings, but API embeddings are useful for semantic search.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# Full agent runtime
# Production deployments should prefer memvid. The memory backend is for tests and local smoke checks.
NEST_AGENT_PROVIDER=mock
NEST_AGENT_MODEL=mock
NEST_AGENT_BASE_URL=
NEST_AGENT_API_KEY_ENV=OPENAI_API_KEY
NEST_AGENT_TIMEOUT_SECONDS=60
NEST_AGENT_MAX_RETRIES=2
NEST_AGENT_TEMPERATURE=0.2
NEST_AGENT_STREAM=false
NEST_AGENT_CODEX_SANDBOX=read-only
NEST_AGENT_CODEX_PROFILE=
NEST_AGENT_CODEX_SKIP_GIT_REPO_CHECK=false
NEST_AGENT_CODEX_PERSIST_SESSION=false
NEST_AGENT_BACKEND=memory
NEST_AGENT_MEMORY_DIR=.nest/memory
NEST_AGENT_WORKSPACE=.
NEST_AGENT_LOG_DIR=.nest/logs
NEST_AGENT_STATE_PATH=.nest/state/agent.db
NEST_AGENT_SKILLS_DIR=.nest/skills
NEST_AGENT_PLUGINS_DIR=.nest/plugins
NEST_AGENT_MCP_CONFIG=.nest/config/mcp_servers.json
NEST_AGENT_CHANNEL_CONFIG=.nest/config/channels.json
NEST_AGENT_MAX_TOOL_ROUNDS=6
NEST_AGENT_CONTEXT_BUDGET_CHARS=18000
NEST_AGENT_CONTEXT_PACK_TOKEN_BUDGET=6000
NEST_AGENT_CONTEXT_PACK_EXPAND_RAW=false
NEST_AGENT_ENABLE_TASK_CAPSULES=true
NEST_AGENT_TASK_CAPSULE_RETENTION_COUNT=1000

# Safety gates. Keep these false unless running a trusted local session with explicit approvals.
NEST_AGENT_ENABLE_AUTO_CONSOLIDATION=false
NEST_AGENT_AUTO_CONSOLIDATION_DRY_RUN=true
NEST_AGENT_SECRET_STORE_PATH=.nest/secrets/local_vault.json
# Use keyring only with a new empty metadata path and a usable host credential service.
NEST_AGENT_SECRET_BACKEND=json
NEST_AGENT_ALLOW_SHELL=false
NEST_AGENT_ALLOW_FILE_WRITE=false
NEST_AGENT_ALLOW_POLICY_WRITES=false
NEST_AGENT_ALLOW_CODEX_CLI=false
# Required before enabling agent-invoked test/lint/repair validation or codex.exec.
# The image must already be present locally, contain the requested command and its
# dependencies, and use an immutable name@sha256:<64 hex> reference. No host fallback.
NEST_AGENT_VALIDATION_CONTAINER_IMAGE=
NEST_AGENT_ALLOW_PLUGIN_INSTALL=false
NEST_AGENT_ALLOW_GIT_COMMIT=false
NEST_AGENT_ALLOW_GIT_PUSH=false
NEST_AGENT_ALLOW_REMOTE_MUTATION=false
NEST_AGENT_GIT_WRITE_MODE=local_branch
NEST_AGENT_PROTECTED_BRANCHES=main,master,release/*
NEST_AGENT_ALLOW_MEMORY_IMPORT=false
NEST_AGENT_ALLOW_EXECUTABLE_SKILLS=false
NEST_AGENT_ALLOW_MCP_NETWORK_ENDPOINTS=false
NEST_AGENT_ENABLE_PROACTIVE_ROUTINES=false
NEST_AGENT_ROUTINE_POLL_INTERVAL_SECONDS=30
NEST_AGENT_ROUTINE_CLAIM_TTL_SECONDS=120
NEST_AGENT_MAX_ROUTINES_PER_TICK=3
NEST_AGENT_ENABLE_CHANNEL_DELIVERY=false
NEST_AGENT_REQUIRE_API_AUTH=false
NEST_AGENT_API_TOKEN=
