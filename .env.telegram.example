# Copy to .env.telegram and fill real values.
# Never commit .env.telegram.

# From @BotFather
TELEGRAM_BOT_TOKEN=

# Random shared secret sent by Telegram as X-Telegram-Bot-Api-Secret-Token.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Protect every public control-plane route except the exact signed Telegram webhook.
# Generate with: openssl rand -hex 32
NEST_AGENT_REQUIRE_API_AUTH=true
NEST_AGENT_API_TOKEN=

# Comma-separated IDs allowed to create runs through this private bot.
# These never grant admin ownership; configure one explicit owner in channels.json.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=

# Ollama Cloud / model provider key for Kestrel's LLM provider.
OLLAMA_API_KEY=

# Public HTTPS tunnel URL, e.g. https://example.trycloudflare.com
# Fill after starting cloudflared.
PUBLIC_URL=

# Optional runtime settings
NEST_AGENT_PROVIDER=ollama-cloud
NEST_AGENT_MODEL=deepseek-v4-pro
NEST_AGENT_API_KEY_ENV=OLLAMA_API_KEY
NEST_AGENT_ENABLE_CHANNEL_DELIVERY=true
KESTREL_PORT=8765

# Optional. Defaults to telegram-poller-health.json beside NEST_AGENT_STATE_PATH
# so isolated Kestrel instances cannot consume one another's poller heartbeat.
# KESTREL_TELEGRAM_HEALTH_PATH=/absolute/path/to/telegram-poller-health.json
