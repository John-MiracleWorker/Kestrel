{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Kestrel",
    "version": "0.1.0",
    "identifier": "ai.kestrel.desktop",
    "build": {
        "frontendDist": "../../web/dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev --workspace=@kestrel/web",
        "beforeBuildCommand": "npm run build --workspace=@kestrel/web"
    },
    "app": {
        "windows": [
            {
                "title": "Kestrel",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:3000 http://localhost:5173; script-src 'self'; style-src 'self' 'unsafe-inline'"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["dmg", "app"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
