{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "svd_xt_1_1.safetensors"
    },
    "_meta": {
      "title": "Load SVD Checkpoint"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "a cinematic scene, smooth motion, high quality"
    },
    "_meta": {
      "title": "CLIP Text Encode (Positive Prompt)"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "bad quality, worst quality, static, blurry, jitter"
    },
    "_meta": {
      "title": "CLIP Text Encode (Negative Prompt)"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "batch_size": 24,
      "height": 576,
      "width": 1024
    },
    "_meta": {
      "title": "Empty Latent Video (24 frames)"
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "cfg": 2.5,
      "denoise": 1.0,
      "latent_image": ["4", 0],
      "model": ["1", 0],
      "negative": ["3", 0],
      "positive": ["2", 0],
      "sampler_name": "euler",
      "scheduler": "karras",
      "seed": 0,
      "steps": 20
    },
    "_meta": {
      "title": "KSampler"
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "7": {
    "class_type": "SaveAnimatedWEBP",
    "inputs": {
      "filename_prefix": "kestrel_vid",
      "fps": 12,
      "images": ["6", 0],
      "lossless": false,
      "method": "default",
      "quality": 85
    },
    "_meta": {
      "title": "Save Video"
    }
  }
}
